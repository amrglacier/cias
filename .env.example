# ============================================================
# CIAS - Environment Variables Template
# Copy this file to `.dev.vars` (for local dev) and set secrets via
# `wrangler secret put <NAME>` (for production)
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- API-Football (via RapidAPI or direct) ---
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Or via RapidAPI:
# API_FOOTBALL_BASE_URL=https://api-football-v1.p.rapidapi.com/v3

# --- LLM API (for Logic Agent / Cross-Discussion) ---
LLM_API_KEY=your-llm-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Odds API (for T0+ market signal capture) ---
ODDS_API_KEY=your-odds-api-key
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# --- Admin API Key (for authenticating write operations) ---
# Set this to protect POST/PUT/DELETE endpoints from unauthorized access.
# If not set, write operations are allowed without auth (NOT recommended for production).
ADMIN_API_KEY=your-admin-api-key

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# --- Optional: Notification webhook ---
NOTIFY_WEBHOOK_URL=
